# Local development environment variables.
# Copy this file to .env.local (recommended) or .env, then replace the placeholders.

OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional: manually control the model dropdown list with comma-separated values.
OPENAI_MODELS=gpt-4o-mini,gpt-4o

# Optional: shared / endpoint-specific token limits. Leave empty to skip max_tokens.
OPENAI_MAX_TOKENS=
OPENAI_GENERATE_MAX_TOKENS=
OPENAI_CHAT_MAX_TOKENS=
