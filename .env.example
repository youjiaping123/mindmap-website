# Local development environment variables.
# Copy this file to .env.local (recommended) or .env, then replace the placeholders.

OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional: manually control the model dropdown list with comma-separated values.
OPENAI_MODELS=gpt-4o-mini,gpt-4o

# Optional: shared / endpoint-specific token limits. Leave empty to skip max_tokens.
OPENAI_MAX_TOKENS=
OPENAI_GENERATE_MAX_TOKENS=
OPENAI_CHAT_MAX_TOKENS=

# Optional: API gate and origin allow-list.
# If API_AUTH_TOKEN is set, trusted callers can send X-App-Token to bypass origin-only mode.
API_AUTH_TOKEN=
# Comma-separated origins, e.g. https://your-site.com,https://preview.your-site.com
ALLOWED_ORIGINS=

# Optional: in-memory rate-limit + daily quota (best-effort on serverless multi-instance).
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_GENERATE_PER_WINDOW=20
API_RATE_LIMIT_CHAT_PER_WINDOW=20
API_RATE_LIMIT_MODELS_PER_WINDOW=60
API_DAILY_QUOTA=800

# Optional: default body size limits (public requests).
API_MAX_CUSTOM_PROMPT_LENGTH=30000
API_MAX_CURRENT_MARKDOWN_LENGTH=20000
API_MAX_CHAT_HISTORY_LENGTH=10000

# Optional: larger limits for trusted requests (with valid X-App-Token).
API_TRUSTED_MAX_CUSTOM_PROMPT_LENGTH=60000
API_TRUSTED_MAX_CURRENT_MARKDOWN_LENGTH=40000
API_TRUSTED_MAX_CHAT_HISTORY_LENGTH=20000
